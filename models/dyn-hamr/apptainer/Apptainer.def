Bootstrap: docker
From: nvidia/cuda:11.7.1-cudnn8-devel-ubuntu22.04

%labels
    Author REIT Team, Modified by Mayank Thakur
    Description Dyn-HaMR inference container (CUDA 11.7, Python 3.10, UV)

%help
    Dyn-HaMR Apptainer container with CUDA + UV-based Python environment.

    Usage:
        apptainer shell container.sif
        apptainer exec --nv <container>.sif python script.py

%files
    /scratch/mthakur/manifold/models/dyn-hamr/dyn-hamr /app/dyn-hamr
    /scratch/mthakur/manifold/models/dyn-hamr/third-party /app/third-party
    /scratch/mthakur/manifold/models/dyn-hamr/setup.py /app/setup.py
    /scratch/mthakur/manifold/models/dyn-hamr/requirements.txt /app/requirements.txt

%post
    set -e

    echo "=============================="
    echo "Installing system dependencies"
    echo "=============================="

    apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3.10 \
        python3.10-venv \
        python3-pip \
        build-essential \
        ninja-build \
        git \
        curl \
        libgl1 \
        libboost-all-dev\
        zlib1g\
        libglib2.0-0 \
        libglib2.0-dev \
        libsm6 \
        libxext6 \
        libxrender1 \
        libgomp1 \
        libgl1-mesa-glx \
        libegl1 \
        libegl-mesa0 \
        libglvnd0

    ln -sf /usr/bin/python3.10 /usr/bin/python
    python -m pip install --upgrade pip

    echo "=============================="
    echo "Installing UV"
    echo "=============================="

    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    echo "=============================="
    echo "Creating isolated Dyn-HaMR Python environment"
    echo "=============================="

    python3.10 -m venv /opt/dynhamr-venv
    export VIRTUAL_ENV=/opt/dynhamr-venv
    export PATH="${VIRTUAL_ENV}/bin:/root/.local/bin:$PATH"
    export UV_PYTHON="${VIRTUAL_ENV}/bin/python"
    python -m pip install --upgrade pip "setuptools<81" wheel packaging
    uv pip install --python "${UV_PYTHON}" "setuptools<81" wheel packaging numpy==1.22.4

    echo "=============================="
    echo "Installing PyTorch (CUDA 11.7)"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" torch==1.13.0 torchvision==0.14.0 --no-build-isolation \
        --index-url https://download.pytorch.org/whl/cu117

    # torch-scatter's legacy build path still imports pkg_resources.
    uv pip install --python "${UV_PYTHON}" "setuptools<81" packaging --no-build-isolation

    uv pip install --python "${UV_PYTHON}" torch-scatter --no-build-isolation \
        -f https://data.pyg.org/whl/torch-1.13.0+cu117.html

    echo "=============================="
    echo "Installing base project"
    echo "=============================="

    cd /app
    uv pip install --python "${UV_PYTHON}" .

    echo "=============================="
    echo "Installing requirements"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" -r /app/requirements.txt --no-build-isolation

    echo "=============================="
    echo "Installing DROID-SLAM"
    echo "=============================="

    cd /app/third-party/DROID-SLAM
    python setup.py install

    echo "=============================="
    echo "Installing HaMeR + ViTPose"
    echo "=============================="

    cd /app/third-party/hamer
    uv pip install --python "${UV_PYTHON}" .[all] --no-build-isolation
    uv pip install --python "${UV_PYTHON}" -v third-party/ViTPose --no-build-isolation

    echo "=============================="
    echo "Pinning Lightning for Torch 1.13"
    echo "=============================="

    # torch._dynamo exists only in torch>=2.0; keep Lightning on the 1.x line.
    uv pip install --python "${UV_PYTHON}" \
        pytorch-lightning==1.9.5 \
        torchmetrics==0.11.4 \
        lightning-utilities==0.11.9 \
        --no-build-isolation

    echo "=============================="
    echo "Fixing Numpy"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" \
        numpy==1.22.4 --no-build-isolation

    echo "=============================="
    echo "Installing MANO"
    echo "=============================="

    cd /app/third-party/manopth
    uv pip install --python "${UV_PYTHON}" .

    echo "=============================="
    echo "Applying pinned broken deps"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" \
        contourpy==1.0.7 \
        matplotlib==3.5.3 \
        opencv-python==4.6.0.66 \
        scikit-image==0.19.3 \
        scipy==1.8.1 \
        --no-build-isolation

    echo "=============================="
    echo "Installing missing utilities"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" loguru arguments future consoleprinter plyfile --no-build-isolation

    echo "=============================="
    echo "Installing human_body_prior"
    echo "=============================="

    cd /app/third-party/human_body_prior
    uv pip install --python "${UV_PYTHON}" -r requirements.txt --no-deps --no-build-isolation
    python setup.py develop

    echo "=============================="
    echo "Installing MediaPipe + protobuf"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" mediapipe==0.10.9 protobuf==3.20.3 --no-build-isolation

    echo "=============================="
    echo "Reinstalling PyTorch last (safety)"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" torch==1.13.0 torchvision==0.14.0 --no-build-isolation \
        --index-url https://download.pytorch.org/whl/cu117

    echo "=============================="
    echo "Final hard pin for binary-compatible scientific stack"
    echo "=============================="

    uv pip install --python "${UV_PYTHON}" --force-reinstall --no-deps --no-build-isolation \
        numpy==1.22.4 \
        scipy==1.8.1 \
        contourpy==1.0.7 \
        matplotlib==3.5.3 \
        opencv-python==4.6.0.66 \
        scikit-image==0.19.3 \
        pandas==1.4.0

    echo "=============================="
    echo "Validating final runtime package versions"
    echo "=============================="

    python - <<'PY'
import sys
import numpy
import scipy
import trimesh
print("FINAL python", sys.executable)
print("FINAL numpy", numpy.__version__)
print("FINAL scipy", scipy.__version__)
print("FINAL trimesh", trimesh.__version__)
PY

    echo "=============================="
    echo "Build completed successfully"
    echo "=============================="

    apt-get clean && rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C
    export PYTHONUNBUFFERED=1
    export VIRTUAL_ENV=/opt/dynhamr-venv
    export PATH="/opt/dynhamr-venv/bin:/root/.local/bin:$PATH"
    export PYTHONNOUSERSITE=1
    export PYOPENGL_PLATFORM=egl
    export EGL_DEVICE_ID=0

%runscript
    echo "=============================="
    echo "Dyn-HaMR Apptainer Container"
    echo "=============================="
    echo "Python path: $(which python)"
    echo "Python: $(python --version)"
    exec "$@"
