Bootstrap: docker
From: nvidia/cuda:11.7.1-cudnn8-devel-ubuntu22.04

%labels
    Author Hamba + UV + Apptainer
    Description Hamba (UV lockfile, CUDA 11.7, Python 3.10)

%help
    Hamba container built from uv.lock
    Usage:
        apptainer exec --nv hamba.sif python demo.py

%environment
    export LC_ALL=C
    export PYTHONUNBUFFERED=1
    export PATH="/.venv/bin:/root/.local/bin:$PATH"

%files
    # /scratch/mthakur/hamba/ /app/Hamba
   /scratch/mthakur/hamba/demo.py                /app/Hamba/demo.py

   # /scratch/mthakur/hamba/hamba                  /app/Hamba/hamba
   /scratch/mthakur/hamba/third-party            /app/Hamba/third-party
   /scratch/mthakur/hamba/VMamba                 /app/Hamba/VMamba

   /scratch/mthakur/hamba/pyproject.toml         /app/Hamba/pyproject.toml
   # /scratch/mthakur/hamba/uv.lock                /app/Hamba/uv.lock
   /scratch/mthakur/hamba/setup.py               /app/Hamba/setup.py


%post
    set -e

    echo "===== System dependencies ====="
    apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3.10 \
        python3-pip \
        python-setuptools \
        build-essential \
        git \
        curl \
        ffmpeg \
        libgl1 \
        libboost-all-dev \
        zlib1g \
        ninja-build \
        ca-certificates

    ln -sf /usr/bin/python3.10 /usr/bin/python

    echo "===== Install uv ====="
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    echo "===== Create venv ====="
    uv venv /.venv --python 3.10

    echo "===== Sync environment from uv.lock ====="
    mkdir -p /app/Hamba
    cd /app/Hamba

    uv pip install pip setuptools==60.2.0 wheel "numpy<2"
    uv pip install torch torchvision --index-url https://download.pytorch.org/whl/cu117

    uv pip install --no-build-isolation mmcv==1.3.9

    export TORCH_CUDA_ARCH_LIST="7.0;7.5;8.0;8.6"
    export FORCE_CUDA="1"

    uv pip install --no-build-isolation .

    #uv sync \
    #    --python /.venv/bin/python \

    echo "===== Final cleanup ====="
    apt-get clean && rm -rf /var/lib/apt/lists/* /root/.cache/uv

%runscript
    echo "======== Hamba Container ========"
    echo "Python: $(python --version)"
    echo "Torch: $(python - <<'EOF'
import torch; print(torch.__version__)
EOF
)"
    exec "$@"
